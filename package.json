{
  "name": "sun-data-analytics-apps",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test:worker": "node --test worker/test/*.test.js",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply DB --local",
    "d1:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "d1:seed:local": "wrangler d1 execute DB --local --file=worker/seeds/example.sql"
  },
  "dependencies": {
    "jose": "6.2.3"
  },
  "devDependencies": {
    "wrangler": "^4.112.0"
  }
}
